---
import ColorHysteresisGame from '../../components/ColorHysteresisGame.svelte';
import ColorHysteresisReveal from '../../components/ColorHysteresisReveal.svelte';
import ColorHysteresisAverageReveal from '../../components/ColorHysteresisAverageReveal.svelte';
import ColorHysteresisPopulationStrip from '../../components/ColorHysteresisPopulationStrip.svelte';
import ColorHysteresisTippingPointComparison from '../../components/ColorHysteresisTippingPointComparison.svelte';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { SHADES } from '../../lib/colorHysteresis';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Color Hysteresis — ${SITE_TITLE}`}
			description="An experiment in perceptual switch-points across a blue-to-green color gradient."
		/>
		<style>
			main {
				width: 960px;
			}
			.prose {
				width: 720px;
				max-width: 100%;
				margin: 0 auto;
			}
			.intro {
				padding-bottom: 2em;
			}
			.game {
				width: 100%;
				max-width: 960px;
				margin: 3em auto;
			}
			.reveal {
				padding-top: 1em;
			}
			.section-note {
				margin-bottom: 1.5em;
				color: rgb(var(--gray));
				font-size: 0.9rem;
				font-style: italic;
			}
			.todo-marker {
				display: inline-block;
				margin-bottom: 1em;
				padding: 0.2em 0.6em;
				border-radius: 4px;
				background-color: rgba(var(--gray-light), 60%);
				color: rgb(var(--gray));
				font-size: 0.8em;
				font-weight: 700;
				letter-spacing: 0.05em;
				text-transform: uppercase;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="prose intro">
				<h1>Color Hysteresis</h1>
				<p>You'll see a color. Click whichever one it looks like to you.</p>
			</section>

			<section class="game" aria-label="Color hysteresis experiment">
				<ColorHysteresisGame client:load shades={SHADES} />
			</section>

			<section class="prose reveal">
				<h2>Your results</h2>
				<ColorHysteresisReveal client:load />
			</section>

			<section class="prose essay">
				<span class="todo-marker">TODO</span>
				<p>
					Placeholder for an essay on Ripley vs. Raffman and individual inconsistency — this will
					be replaced with the full write-up once the experiment and its results are ready to
					discuss; for now it exists to hold the page's typography and rhythm in place.
				</p>
			</section>

			<section class="prose avg-results">
				<h2>Average results</h2>
				<p class="section-note">
					You experienced the colors in a random order — but to compare everyone fairly, we line up
					all the results as if each person had started from blue. Also, gap is defined as the
					average <strong>magnitude</strong> gap.
				</p>
				<ColorHysteresisAverageReveal client:load />
			</section>

			<section class="prose essay">
				<span class="todo-marker">TODO</span>
				<p>But what about the tipping point as a whole?</p>
			</section>

			<section class="prose population">
				<h2>Population tipping points</h2>
				<p class="section-note">
					Tipping point is calculated as the average of one's forward and backward switch.
				</p>
				<ColorHysteresisPopulationStrip client:load />
			</section>

			<section class="prose essay">
				<span class="todo-marker">TODO</span>
				<p>Text placeholder explaining how your tipping point stacks up against everyone else's.</p>
			</section>

			<section class="prose comparison">
				<ColorHysteresisTippingPointComparison client:load />
			</section>

			<section class="prose essay">
				<span class="todo-marker">TODO</span>
				<p>
					Placeholder for an essay on cultural indeterminacy and philosophical implications — this
					will be replaced with the full write-up once the experiment and its results are ready to
					discuss; for now it exists to hold the page's typography and rhythm in place.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
