---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	<style>
		.page-mark {
			display: block;
			margin-bottom: 1rem;
		}
	</style>
	</head>
	<body>
		<Header />
		<main>
			<img src="/favicon-s2.svg" alt="" width="48" height="48" class="page-mark" />
			<h1>Olivia Lund</h1>
			<p>
				This is a place where I publish essays and experiments at the intersection of the liberal arts
				and data science. See what I've been working on <a href="/projects">here</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
