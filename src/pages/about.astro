---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About — ${SITE_TITLE}`} description="About Olivia Lund" />
	</head>
	<body>
		<Header />
		<main>
			<h1>About</h1>
			<p>
				I'm a recent Purdue University graduate with a degree in data science, and I'll be joining
				Susquehanna as a quantitative trader this fall.
			</p>
			<p>
				My interests span philosophy, fashion, music, social science, and game theory. I'm especially
				drawn to the edges of categories, where things resist clean classification and binary thinking
				stops working. I'm interested in combining the liberal arts with computational thinking—using
				writing, data, models, and simulations to explore ideas from different angles.
			</p>
			<p>
				This site is where I think in public. Essays, experiments, things I'm working through.
				Probably a work in progress indefinitely.
			</p>
			<p>
				Outside this I love running, reading a good book, or listening to interesting podcasts.
				Tacos are my favorite food and I'm always taking recommendations.
			</p>
			<p><em>Olivia</em></p>
		</main>
		<Footer />
	</body>
</html>
